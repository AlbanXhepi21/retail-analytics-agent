# Google AI Studio API key — https://aistudio.google.com/
GOOGLE_API_KEY=key

# GCP project ID — used as BigQuery billing / quota project
GCP_PROJECT_ID=ai-retail-company

# Optional: log level (DEBUG shows trace_id, node_path, retries)
LOG_LEVEL=INFO

# Docker + BigQuery via service account JSON (optional alternative to gcloud ADC):
# Point to the path INSIDE the container after you mount the file in docker-compose (see README).
# GOOGLE_APPLICATION_CREDENTIALS=/app/creds/gcp-sa.json

# Docker + gcloud on Windows (optional): path to your gcloud config folder
# GCLOUD_CONFIG=C:/Users/YourName/AppData/Roaming/gcloud
